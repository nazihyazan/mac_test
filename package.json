{
  "name": "floatboard",
  "version": "1.0.15",
  "description": "A fast and unobtrusive floating clipboard manager for Linux",
  "main": "main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build:linux": "electron-builder --linux --publish never -c.directories.output=dist/linux"
  },
  "keywords": [
    "clipboard",
    "floating",
    "electron",
    "productivity"
  ],
  "author": "Nazih <nazih@example.com>",
  "homepage": "https://github.com/nazih/floating-board",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.1.8",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "playwright": "^1.44.0"
  },
  "build": {
    "appId": "com.nazih.floatboard",
    "buildVersion": "1.0.0.0",
    "productName": "FloatBoard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "style.css",
      "upgrade.css",
      "license.js",
      "seo.js",
      "assets/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility;Office;TextTools;",
      "executableName": "floatboard",
      "artifactName": "FloatBoard-${version}-linux.${ext}",
      "icon": "build/icon.png",
      "synopsis": "A floating clipboard manager for Linux.",
      "description": "FloatBoard is a fast, unobtrusive floating clipboard manager designed for productivity. Easily store, organize, and paste your clipboard history."
    },
    "snap": {
      "summary": "Floating clipboard manager",
      "description": "FloatBoard is a productivity-focused, floating clipboard manager that allows you to easily store, organize, and paste your clipboard history directly from a clean, unobtrusive floating overlay. Designed for speed and efficiency.",
      "confinement": "classic",
      "grade": "stable"
    }
  }
}
